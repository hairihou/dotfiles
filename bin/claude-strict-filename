#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///
import json
import os
import re
import sys


def deny(reason: str) -> None:
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": reason,
                }
            }
        )
    )
    sys.exit(0)


if sys.stdin.isatty():
    sys.exit(0)

try:
    payload = json.load(sys.stdin)
except (json.JSONDecodeError, ValueError):
    sys.exit(0)

if payload.get("tool_name") != "Write":
    sys.exit(0)

path = (payload.get("tool_input") or {}).get("file_path", "")
if not path:
    sys.exit(0)

basename = os.path.basename(path)
if not basename:
    sys.exit(0)

try:
    basename.encode("ascii")
except UnicodeEncodeError:
    deny(f"non-ASCII filename blocked by policy: {basename!r}")

if os.path.exists(path):
    sys.exit(0)

stem = basename.lstrip(".").partition(".")[0]
if re.fullmatch(r"[a-z0-9]+(?:[A-Z][A-Za-z0-9]*)+", stem):
    deny(
        f"lowerCamelCase filename blocked by policy: {basename!r} "
        "(use kebab-case or snake_case; PascalCase only for component files)"
    )
