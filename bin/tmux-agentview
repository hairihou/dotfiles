#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///
import os
import subprocess
import sys
import time

if "TMUX" not in os.environ:
    sys.exit("Error: Not inside a tmux session")

AGENTS = ("claude", "codex", "opencode")
RESET = "\033[0m"
SECONDARY = "\033[2m"
WARNING = "\033[33m"

panes = subprocess.run(
    [
        "tmux",
        "list-panes",
        "-a",
        "-F",
        "#{pane_id}\t#{session_name}\t#{pane_current_command}\t#{pane_title}",
    ],
    capture_output=True,
    text=True,
    check=True,
).stdout

rows = []
for line in panes.splitlines():
    pane_id, session, command, title = line.split("\t", 3)
    agent = next((a for a in AGENTS if command.startswith(a)), None)
    if agent is None:
        continue
    running = "⠀" <= title[:1] <= "⣿"
    summary = ""
    if agent == "claude":
        summary = title[1:].lstrip() if running or title[:1] == "✳" else title
    elif agent == "opencode":
        prefix = "OC | "
        summary = title[len(prefix) :] if title.startswith(prefix) else ""
    rows.append((pane_id, session, agent, summary, WARNING if running else SECONDARY))

if not rows:
    print("No agent panes")
    time.sleep(1)
    sys.exit(0)

session_width = max(len(r[1]) for r in rows)
agent_width = max(len(r[2]) for r in rows)
entries = [
    f"{pane_id}\t{color}●{RESET} {session:<{session_width}}  "
    f"{SECONDARY}{agent:<{agent_width}}{f' - {summary}' if summary else ''}{RESET}"
    for pane_id, session, agent, summary, color in rows
]

fzf = subprocess.run(
    [
        "fzf",
        "--ansi",
        "--reverse",
        "--no-sort",
        "--highlight-line",
        "--color",
        "bg+:#1e2939",
        "--pointer",
        "",
        "--delimiter",
        "\t",
        "--with-nth",
        "2",
    ],
    input="\n".join(entries),
    capture_output=True,
    text=True,
)
if fzf.returncode != 0:
    sys.exit(0)

target = fzf.stdout.split("\t", 1)[0]
subprocess.run(["tmux", "switch-client", "-t", target], check=True)
