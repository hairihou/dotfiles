#!/usr/bin/env python3
import json
import shlex
import sys


def deny(reason: str) -> None:
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": "deny",
            "permissionDecisionReason": reason,
        }
    }))
    sys.exit(0)


if sys.stdin.isatty():
    sys.exit(0)

try:
    payload = json.load(sys.stdin)
except (json.JSONDecodeError, ValueError):
    sys.exit(0)

cmd = (payload.get("tool_input") or {}).get("command", "")
if not cmd:
    sys.exit(0)

try:
    tokens = shlex.split(cmd, posix=True)
except ValueError:
    sys.exit(0)

is_pr_create = any(
    tokens[i:i + 3] == ["gh", "pr", "create"]
    for i in range(len(tokens) - 2)
)
if not is_pr_create:
    sys.exit(0)

violations = []

if "--draft" not in tokens:
    violations.append("--draft (create new PR as draft)")

has_assignee = "--assignee=@me" in tokens or any(
    tokens[i] == "--assignee" and tokens[i + 1] == "@me"
    for i in range(len(tokens) - 1)
)
if not has_assignee:
    violations.append("--assignee @me (assign to self)")

if violations:
    reason = "PR rules violated. Add the following flags to `gh pr create`:\n"
    reason += "\n".join(f"  - {v}" for v in violations)
    deny(reason)
