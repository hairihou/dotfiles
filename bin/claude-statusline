#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///
import json
import sys

BRAILLE = "⠀⡀⣀⣤⣶⣿"
GREEN, YELLOW, RED = "\033[92m", "\033[93m", "\033[91m"
RESET = "\033[0m"
SEP = " | "


def gauge(pct: int, warning: int, critical: int) -> str:
    if pct >= critical:
        color = RED
    elif pct >= warning:
        color = YELLOW
    else:
        color = GREEN
    level = max(1, min(10, pct * 10 // 100))
    if level >= 5:
        hi, lo = BRAILLE[5], BRAILLE[level - 5]
    else:
        hi, lo = BRAILLE[level], BRAILLE[0]
    return f"{color}{hi}{lo}{pct}%{RESET}"


try:
    data = json.load(sys.stdin)
    model = (
        (data.get("model", {}).get("display_name") or "unknown").split("(")[0].strip()
    )
    effort = data.get("effort", {}).get("level")
    ctx_size = int(data.get("context_window", {}).get("context_window_size") or 0)
    ctx_pct = int(data.get("context_window", {}).get("used_percentage") or 0)
    raw_5h = data.get("rate_limits", {}).get("five_hour", {}).get("used_percentage")
    rate_5h_pct = int(raw_5h) if raw_5h is not None else -1
    raw_7d = data.get("rate_limits", {}).get("seven_day", {}).get("used_percentage")
    rate_7d_pct = int(raw_7d) if raw_7d is not None else -1
except Exception:
    print("claude")
    sys.exit()

line = model
if ctx_size >= 1_000_000:
    line += " (1M)"
if effort:
    line += f" - {effort}"
line += f"{SEP}context {gauge(ctx_pct, 70, 90)}"
if rate_5h_pct >= 0:
    line += f"{SEP}5h {gauge(rate_5h_pct, 60, 80)}"
else:
    line += f"{SEP}5h {BRAILLE[0]}{BRAILLE[0]}--%"
if rate_7d_pct >= 0:
    line += f"{SEP}7d {gauge(rate_7d_pct, 50, 70)}"
else:
    line += f"{SEP}7d {BRAILLE[0]}{BRAILLE[0]}--%"

print(line)
