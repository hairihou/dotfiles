#!/usr/bin/env python3
import json
import sys

BRAILLE = "⠀⡀⣀⣤⣶⣿"
GREEN, YELLOW, RED = "\033[92m", "\033[93m", "\033[91m"
GRAY, RESET = "\033[90m", "\033[0m"
SEP = f" {GRAY}|{RESET} "


def gauge(pct: int, warning: int, critical: int) -> str:
    if pct >= critical:
        color = RED
    elif pct >= warning:
        color = YELLOW
    else:
        color = GREEN
    level = max(1, min(10, pct * 10 // 100))
    if level >= 5:
        hi, lo = BRAILLE[5], BRAILLE[level - 5]
    else:
        hi, lo = BRAILLE[level], BRAILLE[0]
    return f"{color}{hi}{lo}{pct}%{RESET}"


try:
    data = json.load(sys.stdin)
    model = (data.get("model", {}).get("display_name") or "unknown").split("(")[0].strip()
    ctx_pct = int(data.get("context_window", {}).get("used_percentage") or 0)
    raw_5h = data.get("rate_limits", {}).get("five_hour", {}).get("used_percentage")
    rate_5h_pct = int(raw_5h) if raw_5h is not None else -1
    raw_7d = data.get("rate_limits", {}).get("seven_day", {}).get("used_percentage")
    rate_7d_pct = int(raw_7d) if raw_7d is not None else -1
except Exception:
    print("claude")
    sys.exit()

line = model
line += f"{SEP}{GRAY}ctx{RESET} {gauge(ctx_pct, 70, 90)}"
if rate_5h_pct >= 0:
    line += f"{SEP}{GRAY}5h{RESET} {gauge(rate_5h_pct, 60, 80)}"
else:
    line += f"{SEP}{GRAY}5h {BRAILLE[0]}{BRAILLE[0]}--%{RESET}"
if rate_7d_pct >= 0:
    line += f"{SEP}{GRAY}7d{RESET} {gauge(rate_7d_pct, 50, 70)}"
else:
    line += f"{SEP}{GRAY}7d {BRAILLE[0]}{BRAILLE[0]}--%{RESET}"

print(line)
