#!/usr/bin/env python3
import subprocess
import sys
from pathlib import Path

ESLINT = Path("node_modules/.bin/eslint")
EXTENSIONS = ("*.js", "*.ts", "*.tsx", "*.vue")

if not ESLINT.is_file():
    sys.exit(0)

diff_result = subprocess.run(
    ["git", "diff", "--name-only", "--diff-filter=ACMR", "HEAD", "--"]
    + list(EXTENSIONS),
    capture_output=True,
    text=True,
)
untracked_result = subprocess.run(
    ["git", "ls-files", "--others", "--exclude-standard", "--"] + list(EXTENSIONS),
    capture_output=True,
    text=True,
)
files = sorted(
    set(
        f
        for f in diff_result.stdout.splitlines() + untracked_result.stdout.splitlines()
        if f
    )
)
if not files:
    sys.exit(0)

subprocess.run(
    [str(ESLINT), "--fix", "--rule", "curly: error", "--rule", "eqeqeq: error", "--"]
    + files,
    capture_output=True,
)
