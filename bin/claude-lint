#!/usr/bin/env python3
import json
import shutil
import subprocess
import sys
from pathlib import Path

EXTENSIONS = ("*.ts", "*.tsx", "*.vue")

stdin_data = {}
if not sys.stdin.isatty():
    try:
        stdin_data = json.loads(sys.stdin.read())
    except (json.JSONDecodeError, ValueError):
        pass

if stdin_data.get("stop_hook_active"):
    sys.exit(0)

ast_grep = shutil.which("ast-grep")
sgconfig = (
    Path(__file__).resolve().parent.parent / "public" / "ast-grep" / "sgconfig.yml"
)
if not ast_grep or not sgconfig.is_file():
    sys.exit(0)

diff_result = subprocess.run(
    ["git", "diff", "--name-only", "--diff-filter=ACMR", "HEAD", "--"]
    + list(EXTENSIONS),
    capture_output=True,
    text=True,
)
untracked_result = subprocess.run(
    ["git", "ls-files", "--others", "--exclude-standard", "--"] + list(EXTENSIONS),
    capture_output=True,
    text=True,
)
files = sorted(
    {
        f
        for f in diff_result.stdout.splitlines() + untracked_result.stdout.splitlines()
        if f
    }
)
if not files:
    sys.exit(0)

update = subprocess.run(
    [ast_grep, "scan", "--update-all", "-c", str(sgconfig), "--"] + files,
    capture_output=True,
    text=True,
)
if update.returncode != 0:
    print(
        json.dumps(
            {
                "decision": "block",
                "reason": f"ast-grep --update-all failed:\n\n{update.stderr.strip() or update.stdout.strip()}",
                "hookSpecificOutput": {"hookEventName": "Stop"},
            }
        )
    )
    sys.exit(0)

scan = subprocess.run(
    [ast_grep, "scan", "--color=never", "-c", str(sgconfig), "--"] + files,
    capture_output=True,
    text=True,
)
report = scan.stdout.strip() or scan.stderr.strip()
if report:
    print(
        json.dumps(
            {
                "decision": "block",
                "reason": f"ast-grep found unresolved issues:\n\n{report}",
                "hookSpecificOutput": {"hookEventName": "Stop"},
            }
        )
    )
sys.exit(0)
