#!/usr/bin/env python3
import os
import sys
from pathlib import Path

if sys.stdin.isatty():
    sys.exit(0)

file = os.environ.get("CLAUDE_TOOL_INPUT_FILE_PATH", "")
if not file or not os.path.isfile(file):
    sys.exit(0)

p = Path(file)
try:
    original = p.read_text()
except UnicodeDecodeError:
    sys.exit(0)
fixed = original.rstrip() + "\n"
if fixed != original:
    p.write_text(fixed)
