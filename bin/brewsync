#!/usr/bin/env bash
set -euo pipefail

readonly BREWFILE="$HOME/.Brewfile"
readonly INCLUDE_TYPES=(brew cask tap)

dump_packages() {
  echo "Dumping installed packages to Brewfile..."
  brew bundle dump --global --force
  local pattern content
  pattern=$(IFS='|'; echo "${INCLUDE_TYPES[*]}")
  content=$(grep -E "^(${pattern}) " "$BREWFILE" || true)
  if [[ -z "$content" ]]; then
    echo "Warning: No matching packages found, keeping existing Brewfile"
    return 0
  fi
  printf '%s\n' "$content" > "$BREWFILE"
  local formulae_count
  formulae_count=$(grep -c "^brew " "$BREWFILE" 2>/dev/null || echo 0)
  local cask_count
  cask_count=$(grep -c "^cask " "$BREWFILE" 2>/dev/null || echo 0)
  local total
  total=$((formulae_count + cask_count))
  echo "Dumped $total packages to $BREWFILE"
}

install_packages() {
  if [[ ! -f "$BREWFILE" ]]; then
    echo "Error: $BREWFILE not found"
    exit 1
  fi

  echo "Installing packages from Brewfile..."
  brew bundle --global
  echo "Installation complete"
}

prune_packages() {
  if [[ ! -f "$BREWFILE" ]]; then
    echo "Error: $BREWFILE not found"
    exit 1
  fi

  local cleanup_output
  cleanup_output=$(brew bundle cleanup --global 2>&1) || true

  if [[ -z "$cleanup_output" ]]; then
    echo 'No packages to remove'
    return 0
  fi

  echo "The following packages are not in $BREWFILE:"
  echo "$cleanup_output"
  echo -n 'Remove these packages? (y/n): '
  read -r response < /dev/tty

  if [[ ! "$response" =~ ^[Yy]([Ee][Ss])?$ ]]; then
    echo 'Cancelled'
    return 0
  fi

  echo "Removing packages..."
  brew bundle cleanup --force --global
  echo "Cleanup complete"
}

main() {
  if ! command -v brew > /dev/null 2>&1; then
    echo "Error: 'brew' command not found"
    exit 1
  fi

  case "${1:-}" in
    --dump)
      dump_packages
      ;;
    --prune)
      prune_packages
      ;;
    '')
      install_packages
      ;;
    *)
      echo "Error: Unknown option: $1"
      exit 1
      ;;
  esac
}

main "$@"
